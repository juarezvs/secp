// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/_kernel/db/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum MotivoEncerramentoSessao {
  LOGOUT
  FECHAMENTO_CLIENTE
  TIMEOUT
  EXPIRADA
  REVOGADA_ADMIN
}

enum PapelSistema {
  SERVIDOR
  GESTOR
  NUTEC
  SECAP
  DIREF
  AUDITOR
  ADMIN
}

enum RegimeTrabalho {
  PRESENCIAL
  TELETRABALHO
  HIBRIDO
}

enum TipoJornada {
  SETE_HORAS
  OITO_HORAS
  ESPECIAL
  DIFERENCIADA
}

enum TipoMarcacao {
  ENTRADA
  SAIDA
  SAIDA_INTERVALO
  RETORNO_INTERVALO
}

enum OrigemMarcacao {
  DISPOSITIVO_BIOMETRICO
  METODO_ALTERNATIVO
  EXCECAO_MANUAL
}

enum StatusApuracao {
  OK
  INCONSISTENTE
  PENDENTE_REGULARIZACAO
  HOMOLOGADO
  FECHADO
}

enum TipoLancamentoBancoHoras {
  CREDITO
  DEBITO
  COMPENSACAO
  EXCEDENTE_SABADO
  EXCEDENTE_DOMINGO_FERIADO
  EXCEDENTE_NOTURNO
  NAO_AUTORIZADO
  ACIMA_LIMITE
  AJUSTE
}

enum TipoAutorizacao {
  HORA_EXTRA_CREDITO
  COMPENSAR_DEBITO
  FRUIR_CREDITO
  ATIVIDADE_EXTERNA
  VIAGEM
  CAPACITACAO
  DISPENSA_PONTO
  REFERENDO_ACIMA_LIMITE
}

enum StatusAutorizacao {
  RASCUNHO
  ENVIADA
  APROVADA
  REJEITADA
  CANCELADA
}

enum TipoUnidadeOrganizacional {
  JUSTICA_FEDERAL
  SECAO_JUDICIARIA
  SUBSECAO_JUDICIARIA
  DIRETORIA
  DEPARTAMENTO
  SECRETARIA
  NUCLEO
  SECAO
  SETOR
  SERVICO
  SUBDEPARTAMENTO
}

enum StatusArquivoAfd {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

//////////////////////////////////////////////////////
// ORGANIZAÇÃO
//////////////////////////////////////////////////////

model Organizacao {
  id        String   @id @default(cuid()) @map("id")
  sigla     String   @unique @map("sigla")
  nome      String   @map("nome")
  ativa     Boolean  @default(true) @map("ativa")
  createdAt DateTime @default(now()) @map("criado_em")
  updatedAt DateTime @updatedAt @map("atualizado_em")

  unidades         UnidadeOrganizacional[]
  usuarios         Usuario[]
  servidores       Servidor[]
  feriados         Feriado[]
  logsAuditoria    LogAuditoria[]
  sessoesAuditadas SessaoAuditoria[]
  importacoesAfd   ImportacaoAfd[]

  @@map("organizacoes")
}

model UnidadeOrganizacional {
  id            String                    @id @default(cuid()) @map("id")
  organizacaoId String                    @map("organizacao_id")
  unidadePaiId  String?                   @map("unidade_pai_id")
  gestorId      String?                   @map("gestor_id")
  nome          String                    @map("nome")
  sigla         String                    @unique @map("sigla")
  tipo          TipoUnidadeOrganizacional @map("tipo")
  ativa         Boolean                   @default(true) @map("ativa")
  createdAt     DateTime                  @default(now()) @map("criado_em")
  updatedAt     DateTime                  @updatedAt @map("atualizado_em")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)

  unidadePai  UnidadeOrganizacional?  @relation("HierarquiaUnidades", fields: [unidadePaiId], references: [id])
  subunidades UnidadeOrganizacional[] @relation("HierarquiaUnidades")

  gestor Usuario? @relation("GestorUnidade", fields: [gestorId], references: [id])

  servidores              Servidor[]
  dispositivosBiometricos DispositivoBiometrico[]
  delegacoes              Delegacao[]
  perfisUsuario           PerfilUsuario[]

  @@index([organizacaoId, unidadePaiId], map: "idx_unidades_organizacao_pai")
  @@index([organizacaoId, tipo], map: "idx_unidades_organizacao_tipo")
  @@map("unidades_organizacionais")
}

//////////////////////////////////////////////////////
// AUTH / USUÁRIOS
//////////////////////////////////////////////////////

model PerfilUsuario {
  id        String  @id @default(cuid()) @map("id")
  usuarioId String  @unique @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  onboardingConcluido Boolean @default(false) @map("onboarding_concluido")
  matricula           String? @map("matricula")
  cpf                 String? @map("cpf")

  unidadeOrganizacionalId String?                @map("unidade_organizacional_id")
  unidadeOrganizacional   UnidadeOrganizacional? @relation(fields: [unidadeOrganizacionalId], references: [id])

  createdAt DateTime @default(now()) @map("criado_em")
  updatedAt DateTime @updatedAt @map("atualizado_em")

  @@map("perfis_usuarios")
}

model Usuario {
  id            String         @id @default(cuid()) @map("id")
  organizacaoId String         @map("organizacao_id")
  matricula     String         @unique @map("matricula")
  email         String?        @unique @map("email")
  nome          String         @map("nome")
  cpf           String         @unique @map("cpf")
  emailVerified DateTime?      @map("email_verificado_em")
  papeis        PapelSistema[] @map("papeis")
  ativo         Boolean        @default(true) @map("ativo")
  imagem        String?        @map("imagem")
  createdAt     DateTime       @default(now()) @map("criado_em")
  updatedAt     DateTime       @updatedAt @map("atualizado_em")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)

  servidor Servidor?

  contas           Conta[]
  sessoes          Sessao[]
  autenticadores   Autenticador[]
  sessoesAuditadas SessaoAuditoria[]

  perfil PerfilUsuario?

  unidadesGerenciadas UnidadeOrganizacional[] @relation("GestorUnidade")

  delegacoesCedidas   Delegacao[] @relation("UsuarioDelegante")
  delegacoesRecebidas Delegacao[] @relation("UsuarioDelegado")

  logsAuditoria LogAuditoria[]

  @@map("usuarios")
}

model Conta {
  id              String   @id @default(cuid()) @map("id")
  usuarioId       String   @map("usuario_id")
  tipo            String   @map("tipo")
  provedor        String   @map("provedor")
  contaProvedorId String   @map("conta_provedor_id")
  refreshToken    String?  @map("refresh_token")
  accessToken     String?  @map("access_token")
  expiresAt       Int?     @map("expira_em")
  tokenType       String?  @map("tipo_token")
  scope           String?  @map("escopo")
  idToken         String?  @map("id_token")
  sessionState    String?  @map("estado_sessao")
  createdAt       DateTime @default(now()) @map("criado_em")
  updatedAt       DateTime @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([provedor, contaProvedorId], map: "uk_contas_provedor_conta")
  @@map("contas")
}

model Sessao {
  id          String   @id @default(cuid()) @map("id")
  tokenSessao String   @unique @map("token_sessao")
  usuarioId   String   @map("usuario_id")
  expiraEm    DateTime @map("expira_em")
  createdAt   DateTime @default(now()) @map("criado_em")
  updatedAt   DateTime @updatedAt @map("atualizado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("sessoes")
}

model TokenVerificacao {
  identificador String   @map("identificador")
  token         String   @unique @map("token")
  expiraEm      DateTime @map("expira_em")

  @@unique([identificador, token], map: "uk_tokens_verificacao_identificador_token")
  @@map("tokens_verificacao")
}

model Autenticador {
  credencialId           String  @unique @map("credencial_id")
  usuarioId              String  @map("usuario_id")
  contaProvedorId        String  @map("conta_provedor_id")
  chavePublicaCredencial String  @map("chave_publica_credencial")
  contador               Int     @map("contador")
  tipoDispositivo        String  @map("tipo_dispositivo")
  backupRealizado        Boolean @map("backup_realizado")
  transportes            String? @map("transportes")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([usuarioId, credencialId])
  @@map("autenticadores")
}

model SessaoAuditoria {
  id                 String                    @id @default(cuid()) @map("id")
  usuarioId          String                    @map("usuario_id")
  organizacaoId      String                    @map("organizacao_id")
  loginEm            DateTime                  @default(now()) @map("login_em")
  ultimoAcessoEm     DateTime                  @default(now()) @map("ultimo_acesso_em")
  encerradaEm        DateTime?                 @map("encerrada_em")
  motivoEncerramento MotivoEncerramentoSessao? @map("motivo_encerramento")
  ip                 String?                   @map("ip")
  userAgent          String?                   @map("user_agent")
  jwtId              String?                   @unique @map("jwt_id")

  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)

  @@index([usuarioId, ultimoAcessoEm], map: "idx_sessoes_auditoria_usuario_ultimo_acesso")
  @@index([encerradaEm], map: "idx_sessoes_auditoria_encerrada_em")
  @@map("sessoes_auditoria")
}

//////////////////////////////////////////////////////
// SERVIDOR / PONTO
//////////////////////////////////////////////////////

model Servidor {
  id                      String         @id @default(cuid()) @map("id")
  organizacaoId           String         @map("organizacao_id")
  usuarioId               String?        @unique @map("usuario_id")
  unidadeOrganizacionalId String         @map("unidade_organizacional_id")
  matricula               String         @unique @map("matricula")
  regimeTrabalho          RegimeTrabalho @default(PRESENCIAL) @map("regime_trabalho")
  tipoJornada             TipoJornada    @map("tipo_jornada")
  comissionado            Boolean        @default(false) @map("comissionado")
  oficialJustica          Boolean        @default(false) @map("oficial_justica")
  dispensaPonto           Boolean        @default(false) @map("dispensa_ponto")
  createdAt               DateTime       @default(now()) @map("criado_em")
  updatedAt               DateTime       @updatedAt @map("atualizado_em")

  organizacao           Organizacao           @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  usuario               Usuario?              @relation(fields: [usuarioId], references: [id])
  unidadeOrganizacional UnidadeOrganizacional @relation(fields: [unidadeOrganizacionalId], references: [id])

  atribuicoesJornada      AtribuicaoJornada[]
  marcacoes               MarcacaoPonto[]
  apuracoesDiarias        ApuracaoDiaria[]
  lancamentosBancoHoras   LancamentoBancoHoras[]
  atividadesExternas      AtividadeExterna[]
  viagens                 Viagem[]
  capacitacoes            Capacitacao[]
  apuracoesMensais        ApuracaoMensal[]
  solicitacoesAutorizacao SolicitacaoAutorizacao[]

  @@index([organizacaoId, unidadeOrganizacionalId], map: "idx_servidores_organizacao_unidade")
  @@map("servidores")
}

model JornadaTrabalho {
  id                  String      @id @default(cuid()) @map("id")
  nome                String      @map("nome")
  tipoJornada         TipoJornada @map("tipo_jornada")
  minutosPorDia       Int         @map("minutos_por_dia")
  intervaloMinimoMin  Int?        @map("intervalo_minimo_min")
  intervaloMaximoMin  Int?        @map("intervalo_maximo_min")
  flexEntradaMin      Int         @map("flex_entrada_min")
  flexSaidaMin        Int         @map("flex_saida_min")
  permiteAntesSeis    Boolean     @default(false) @map("permite_antes_seis")
  permiteAposDezenove Boolean     @default(false) @map("permite_apos_dezenove")
  createdAt           DateTime    @default(now()) @map("criado_em")
  updatedAt           DateTime    @updatedAt @map("atualizado_em")

  atribuicoes AtribuicaoJornada[]

  @@map("jornadas_trabalho")
}

model AtribuicaoJornada {
  id          String    @id @default(cuid()) @map("id")
  servidorId  String    @map("servidor_id")
  jornadaId   String    @map("jornada_id")
  vigenciaIni DateTime  @map("vigencia_inicio")
  vigenciaFim DateTime? @map("vigencia_fim")

  servidor Servidor        @relation(fields: [servidorId], references: [id], onDelete: Cascade)
  jornada  JornadaTrabalho @relation(fields: [jornadaId], references: [id], onDelete: Cascade)

  @@index([servidorId, vigenciaIni], map: "idx_atribuicoes_jornada_servidor_vigencia")
  @@map("atribuicoes_jornada")
}

model DispositivoBiometrico {
  id                      String   @id @default(cuid()) @map("id")
  unidadeOrganizacionalId String   @map("unidade_organizacional_id")
  nome                    String   @map("nome")
  serial                  String?  @unique @map("serial")
  ativo                   Boolean  @default(true) @map("ativo")
  createdAt               DateTime @default(now()) @map("criado_em")
  updatedAt               DateTime @updatedAt @map("atualizado_em")

  unidadeOrganizacional UnidadeOrganizacional @relation(fields: [unidadeOrganizacionalId], references: [id], onDelete: Cascade)
  marcacoes             MarcacaoPonto[]

  @@map("dispositivos_biometricos")
}

model MarcacaoPonto {
  id              String         @id @default(cuid()) @map("id")
  servidorId      String         @map("servidor_id")
  ocorridaEm      DateTime       @map("ocorrida_em")
  tipoMarcacao    TipoMarcacao   @map("tipo_marcacao")
  origemMarcacao  OrigemMarcacao @map("origem_marcacao")
  dispositivoId   String?        @map("dispositivo_id")
  payloadBruto    Json?          @map("payload_bruto")
  hashIntegridade String?        @map("hash_integridade")
  createdAt       DateTime       @default(now()) @map("criado_em")

  servidor    Servidor               @relation(fields: [servidorId], references: [id], onDelete: Cascade)
  dispositivo DispositivoBiometrico? @relation(fields: [dispositivoId], references: [id])

  @@unique([servidorId, ocorridaEm, origemMarcacao], map: "uq_marcacao_servidor_data_origem")
  @@index([servidorId, ocorridaEm], map: "idx_marcacoes_servidor_ocorrida")
  @@map("marcacoes_ponto")
}

//////////////////////////////////////////////////////
// EVENTOS DE EFETIVO EXERCÍCIO
//////////////////////////////////////////////////////

model AtividadeExterna {
  id                       String   @id @default(cuid()) @map("id")
  servidorId               String   @map("servidor_id")
  inicioEm                 DateTime @map("inicio_em")
  fimEm                    DateTime @map("fim_em")
  descricao                String   @map("descricao")
  urlDocumentoComprovante  String?  @map("url_documento_comprovante")
  solicitacaoAutorizacaoId String?  @unique @map("solicitacao_autorizacao_id")
  createdAt                DateTime @default(now()) @map("criado_em")
  updatedAt                DateTime @updatedAt @map("atualizado_em")

  servidor               Servidor                @relation(fields: [servidorId], references: [id], onDelete: Cascade)
  solicitacaoAutorizacao SolicitacaoAutorizacao? @relation(fields: [solicitacaoAutorizacaoId], references: [id])

  @@map("atividades_externas")
}

model Viagem {
  id                       String   @id @default(cuid()) @map("id")
  servidorId               String   @map("servidor_id")
  inicioEm                 DateTime @map("inicio_em")
  fimEm                    DateTime @map("fim_em")
  destino                  String   @map("destino")
  solicitacaoAutorizacaoId String?  @unique @map("solicitacao_autorizacao_id")
  createdAt                DateTime @default(now()) @map("criado_em")
  updatedAt                DateTime @updatedAt @map("atualizado_em")

  servidor               Servidor                @relation(fields: [servidorId], references: [id], onDelete: Cascade)
  solicitacaoAutorizacao SolicitacaoAutorizacao? @relation(fields: [solicitacaoAutorizacaoId], references: [id])

  @@map("viagens")
}

model Capacitacao {
  id                       String   @id @default(cuid()) @map("id")
  servidorId               String   @map("servidor_id")
  data                     DateTime @map("data")
  horas                    Int      @map("horas")
  interna                  Boolean  @map("interna")
  urlDocumentoComprovante  String?  @map("url_documento_comprovante")
  solicitacaoAutorizacaoId String?  @unique @map("solicitacao_autorizacao_id")
  createdAt                DateTime @default(now()) @map("criado_em")
  updatedAt                DateTime @updatedAt @map("atualizado_em")

  servidor               Servidor                @relation(fields: [servidorId], references: [id], onDelete: Cascade)
  solicitacaoAutorizacao SolicitacaoAutorizacao? @relation(fields: [solicitacaoAutorizacaoId], references: [id])

  @@map("capacitacoes")
}

//////////////////////////////////////////////////////
// APURAÇÃO
//////////////////////////////////////////////////////

model ApuracaoDiaria {
  id                             String         @id @default(cuid()) @map("id")
  servidorId                     String         @map("servidor_id")
  data                           DateTime       @map("data")
  minutosPrevistos               Int            @map("minutos_previstos")
  minutosTrabalhados             Int            @map("minutos_trabalhados")
  minutosIntervalo               Int            @map("minutos_intervalo")
  minutosDebito                  Int            @map("minutos_debito")
  minutosCredito                 Int            @map("minutos_credito")
  minutosNaoAutorizados          Int            @map("minutos_nao_autorizados")
  minutosAcimaLimite             Int            @map("minutos_acima_limite")
  minutosExcedenteSabado         Int            @map("minutos_excedente_sabado")
  minutosExcedenteDomingoFeriado Int            @map("minutos_excedente_domingo_feriado")
  minutosExcedenteNoturno        Int            @map("minutos_excedente_noturno")
  status                         StatusApuracao @default(OK) @map("status")
  flags                          String[]       @map("flags")

  servidor Servidor @relation(fields: [servidorId], references: [id], onDelete: Cascade)

  @@unique([servidorId, data], map: "uk_apuracoes_diarias_servidor_data")
  @@map("apuracoes_diarias")
}

model ApuracaoMensal {
  id                 String         @id @default(cuid()) @map("id")
  servidorId         String         @map("servidor_id")
  referenciaMes      String         @map("referencia_mes")
  minutosPrevistos   Int            @map("minutos_previstos")
  minutosTrabalhados Int            @map("minutos_trabalhados")
  minutosDebito      Int            @map("minutos_debito")
  minutosCredito     Int            @map("minutos_credito")
  saldoMinutos       Int            @map("saldo_minutos")
  status             StatusApuracao @default(OK) @map("status")
  homologadoEm       DateTime?      @map("homologado_em")
  homologadoPor      String?        @map("homologado_por")

  servidor Servidor @relation(fields: [servidorId], references: [id], onDelete: Cascade)

  @@unique([servidorId, referenciaMes], map: "uk_apuracoes_mensais_servidor_mes")
  @@map("apuracoes_mensais")
}

model LancamentoBancoHoras {
  id               String                   @id @default(cuid()) @map("id")
  servidorId       String                   @map("servidor_id")
  referenciaMes    String                   @map("referencia_mes")
  tipoLancamento   TipoLancamentoBancoHoras @map("tipo_lancamento")
  minutos          Int                      @map("minutos")
  fator            Float?                   @map("fator")
  referenciaOrigem Json?                    @map("referencia_origem")
  createdAt        DateTime                 @default(now()) @map("criado_em")

  servidor Servidor @relation(fields: [servidorId], references: [id], onDelete: Cascade)

  @@index([servidorId, referenciaMes], map: "idx_lancamentos_banco_horas_servidor_mes")
  @@map("lancamentos_banco_horas")
}

//////////////////////////////////////////////////////
// AUTORIZAÇÕES
//////////////////////////////////////////////////////

model SolicitacaoAutorizacao {
  id                String            @id @default(cuid()) @map("id")
  servidorId        String            @map("servidor_id")
  tipoAutorizacao   TipoAutorizacao   @map("tipo_autorizacao")
  status            StatusAutorizacao @default(RASCUNHO) @map("status")
  solicitadaEm      DateTime          @default(now()) @map("solicitada_em")
  inicioEm          DateTime?         @map("inicio_em")
  fimEm             DateTime?         @map("fim_em")
  minutos           Int?              @map("minutos")
  justificativa     String            @map("justificativa")
  decididaEm        DateTime?         @map("decidida_em")
  decididaPor       String?           @map("decidida_por")
  observacaoDecisao String?           @map("observacao_decisao")

  servidor Servidor @relation(fields: [servidorId], references: [id], onDelete: Cascade)

  atividadeExterna AtividadeExterna?
  viagem           Viagem?
  capacitacao      Capacitacao?

  @@index([servidorId, tipoAutorizacao, status], map: "idx_solicitacoes_autorizacao_servidor_tipo_status")
  @@map("solicitacoes_autorizacao")
}

model Delegacao {
  id                      String    @id @default(cuid()) @map("id")
  unidadeOrganizacionalId String    @map("unidade_organizacional_id")
  usuarioDeleganteId      String    @map("usuario_delegante_id")
  usuarioDelegadoId       String    @map("usuario_delegado_id")
  vigenciaInicio          DateTime  @map("vigencia_inicio")
  vigenciaFim             DateTime? @map("vigencia_fim")
  observacao              String?   @map("observacao")
  createdAt               DateTime  @default(now()) @map("criado_em")
  updatedAt               DateTime  @updatedAt @map("atualizado_em")

  unidadeOrganizacional UnidadeOrganizacional @relation(fields: [unidadeOrganizacionalId], references: [id], onDelete: Cascade)
  usuarioDelegante      Usuario               @relation("UsuarioDelegante", fields: [usuarioDeleganteId], references: [id], onDelete: Cascade)
  usuarioDelegado       Usuario               @relation("UsuarioDelegado", fields: [usuarioDelegadoId], references: [id], onDelete: Cascade)

  @@index([unidadeOrganizacionalId, vigenciaInicio], map: "idx_delegacoes_unidade_vigencia")
  @@map("delegacoes")
}

//////////////////////////////////////////////////////
// APOIO / AUDITORIA
//////////////////////////////////////////////////////

model Feriado {
  id            String   @id @default(cuid()) @map("id")
  organizacaoId String   @map("organizacao_id")
  data          DateTime @map("data")
  nome          String   @map("nome")
  nacional      Boolean  @default(false) @map("nacional")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)

  @@unique([organizacaoId, data], map: "uk_feriados_organizacao_data")
  @@map("feriados")
}

model LogAuditoria {
  id            String   @id @default(cuid()) @map("id")
  organizacaoId String   @map("organizacao_id")
  usuarioAtorId String?  @map("usuario_ator_id")
  acao          String   @map("acao")
  entidade      String   @map("entidade")
  entidadeId    String   @map("entidade_id")
  dados         Json?    @map("dados")
  createdAt     DateTime @default(now()) @map("criado_em")

  organizacao Organizacao @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  usuarioAtor Usuario?    @relation(fields: [usuarioAtorId], references: [id])

  @@index([organizacaoId, createdAt], map: "idx_logs_auditoria_organizacao_criado_em")
  @@map("logs_auditoria")
}

//////////////////////////////////////////////////////
// AFD
//////////////////////////////////////////////////////

model ImportacaoAfd {
  id            String   @id @default(cuid()) @map("id")
  organizacaoId String   @map("organizacao_id")
  source        String?  @map("origem")
  createdAt     DateTime @default(now()) @map("criado_em")

  organizacao Organizacao  @relation(fields: [organizacaoId], references: [id], onDelete: Cascade)
  arquivos    ArquivoAfd[]

  @@map("importacoes_afd")
}

model ArquivoAfd {
  id             String           @id @default(cuid()) @map("id")
  importacaoId   String           @map("importacao_id")
  nomeOriginal   String           @map("nome_original")
  nomeArmazenado String           @map("nome_armazenado")
  caminhoArquivo String           @map("caminho_arquivo")
  sha256         String           @map("sha256")
  tamanhoBytes   Int              @map("tamanho_bytes")
  mimeType       String?          @map("mime_type")
  textoBruto     String?          @map("texto_bruto") @db.Text
  jsonParseado   Json?            @map("json_parseado")
  status         StatusArquivoAfd @default(PENDENTE) @map("status")
  mensagemErro   String?          @map("mensagem_erro") @db.Text
  createdAt      DateTime         @default(now()) @map("criado_em")
  processadoEm   DateTime?        @map("processado_em")

  importacao ImportacaoAfd @relation(fields: [importacaoId], references: [id], onDelete: Cascade)

  @@map("arquivos_afd")
}
